# Normalize line endings: let git decide on checkin, keep platform-native on checkout
* text=auto

# Scripts that must keep specific endings
*.ps1 text eol=crlf
*.sh  text eol=lf

# Treat as binary (no diff/merge)
*.dll binary
*.lib binary
*.so  binary
*.dylib binary
*.pdb binary

# Media test fixtures (MPEG transport stream / mp4) are binary, not source text.
*.ts  binary
*.mp4 binary
*.mkv binary
*.flv binary
